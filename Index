                        const tx = p.x + Math.cos(a) * r;
                        const ty = p.y + Math.sin(a) * r * 0.75 - 20;
                        const s = 10 + noise(i * 6.1) * 9;
                        detailsHTML += `
                            <rect x="${tx - 1.2}" y="${ty + s * 0.9}" width="2.4" height="${s * 0.5}" fill="#3a2a16" />
                            <polygon points="${tx},${ty - s} ${tx - s * 0.55},${ty + s * 0.55} ${tx + s * 0.55},${ty + s * 0.55}" fill="url(#treeGrad)" stroke="#123018" stroke-width="0.5" />
                            <polygon points="${tx},${ty - s * 0.55} ${tx - s * 0.42},${ty + s * 0.85} ${tx + s * 0.42},${ty + s * 0.85}" fill="url(#treeGrad)" opacity="0.9" />
                        `;
                    }
                    // Colina suave
                    detailsHTML += `<ellipse cx="${p.x - 70}" cy="${p.y + 70}" rx="55" ry="20" fill="#3f8a44" opacity="0.4" filter="url(#mapBlurHard)" />`;
                }

                if (pos.terrain === "mountain") {
                    // Cordillera dorada con picos nevados sombreados
                    const peaks = [
                        { dx: -70, dy: 10, h: 95, w: 60 },
                        { dx: -10, dy: -10, h: 120, w: 70 },
                        { dx: 55, dy: 15, h: 100, w: 65 },
                        { dx: 110, dy: 30, h: 75, w: 50 }
                    ];
                    peaks.forEach((pk, i) => {
                        const bx = p.x + pk.dx, by = p.y + pk.dy;
                        detailsHTML += `
                            <polygon points="${bx - pk.w/2},${by + 10} ${bx},${by - pk.h} ${bx + pk.w/2},${by + 10}" fill="url(#rockGrad)" stroke="#2c2218" stroke-width="0.6" />
                            <polygon points="${bx - pk.w*0.18},${by - pk.h*0.6} ${bx},${by - pk.h} ${bx + pk.w*0.18},${by - pk.h*0.6} ${bx + pk.w*0.08},${by - pk.h*0.42} ${bx},${by - pk.h*0.52} ${bx - pk.w*0.08},${by - pk.h*0.42}" fill="url(#snowCapGrad)" />
                        `;
                    });
                }

                if (pos.terrain === "crimson") {
                    // Picos rocosos rojizos + árboles secos
                    const peaks = [{ dx: -50, dy: 20, h: 80, w: 55 }, { dx: 20, dy: -5, h: 105, w: 65 }, { dx: 85, dy: 25, h: 70, w: 48 }];
                    peaks.forEach(pk => {
                        const bx = p.x + pk.dx, by = p.y + pk.dy;
                        detailsHTML += `<polygon points="${bx - pk.w/2},${by + 10} ${bx},${by - pk.h} ${bx + pk.w/2},${by + 10}" fill="#5a1e1a" stroke="#2c0d0a" stroke-width="0.6" />
                        <polygon points="${bx - pk.w/2},${by + 10} ${bx - pk.w*0.1},${by - pk.h*0.3} ${bx},${by - pk.h}" fill="#7a2b24" opacity="0.6" />`;
                    });
                    for (let i = 0; i < 7; i++) {
                        const a = noise(i * 5.5 + 9) * Math.PI * 2;
                        const r = 60 + noise(i * 2.2) * 60;
                        const tx = p.x + Math.cos(a) * r;
                        const ty = p.y + Math.sin(a) * r * 0.7 + 30;
                        detailsHTML += `<path d="M ${tx} ${ty} L ${tx - 4} ${ty - 16} M ${tx} ${ty} L ${tx + 5} ${ty - 13} M ${tx} ${ty} L ${tx} ${ty - 18}" stroke="#1c0e0a" stroke-width="1.4" stroke-linecap="round" />`;
                    }
                }

                if (pos.terrain === "ice") {
                    // Esquirlas de hielo brillantes + nieve
                    detailsHTML += `<ellipse cx="${p.x}" cy="${p.y + 40}" rx="100" ry="35" fill="#eaf6fb" opacity="0.45" filter="url(#mapBlurHard)" />`;
                    for (let i = 0; i < 8; i++) {
                        const a = noise(i * 6.6 + 3) * Math.PI * 2;
                        const r = 30 + noise(i * 3.3) * 90;
                        const ix = p.x + Math.cos(a) * r;
                        const iy = p.y + Math.sin(a) * r * 0.7 - 30;
                        const h = 30 + noise(i * 7.7) * 40;
                        detailsHTML += `<polygon points="${ix - 6},${iy + h} ${ix},${iy - h} ${ix + 6},${iy + h}" fill="url(#iceShard)" opacity="0.85" stroke="#fff" stroke-opacity="0.4" stroke-width="0.5" />`;
                    }
                }

                if (pos.terrain === "crystal") {
                    // Resplandor + cúmulo de cristales amatista
                    detailsHTML += `<circle cx="${p.x}" cy="${p.y - 10}" r="120" fill="url(#crystalGlow)" opacity="0.55" />`;
                    for (let i = 0; i < 10; i++) {
                        const a = noise(i * 8.8 + 5) * Math.PI * 2;
                        const r = 25 + noise(i * 4.4) * 80;
                        const cx2 = p.x + Math.cos(a) * r;
                        const cy2 = p.y + Math.sin(a) * r * 0.7 - 40;
                        const h = 25 + noise(i * 9.9) * 45;
                        const w = 7 + noise(i * 2.1) * 6;
                        detailsHTML += `<polygon points="${cx2 - w},${cy2 + h*0.4} ${cx2},${cy2 - h} ${cx2 + w},${cy2 + h*0.4} ${cx2},${cy2 + h*0.6}" fill="url(#crystalShard)" opacity="0.9" stroke="#fff" stroke-opacity="0.3" stroke-width="0.4" />`;
                    }
                }
            });

            // ---------- CORDILLERA CENTRAL DECORATIVA (entre reinos) ----------
            const centralPeaks = [
                { x: 430, y: 230, h: 130, w: 90 }, { x: 510, y: 245, h: 160, w: 100 },
                { x: 600, y: 215, h: 140, w: 95 }, { x: 470, y: 260, h: 100, w: 70 }
            ];
            centralPeaks.forEach(pk => {
                detailsHTML += `
                    <polygon points="${pk.x - pk.w/2},${pk.y + 14} ${pk.x},${pk.y - pk.h} ${pk.x + pk.w/2},${pk.y + 14}" fill="url(#rockGrad)" opacity="0.85" stroke="#1c1917" stroke-width="0.6" stroke-opacity="0.4" />
                    <polygon points="${pk.x - pk.w*0.16},${pk.y - pk.h*0.55} ${pk.x},${pk.y - pk.h} ${pk.x + pk.w*0.16},${pk.y - pk.h*0.55} ${pk.x},${pk.y - pk.h*0.42}" fill="#fff" opacity="0.85" />
                `;
            });

            // ---------- NUBES DIFUMINADAS ----------
            for (let i = 0; i < 5; i++) {
                const cx = noise(i * 11.3 + 1) * 1000;
                const cy = noise(i * 13.7 + 2) * 140 + 10;
                detailsHTML += `<ellipse cx="${cx}" cy="${cy}" rx="${60 + noise(i)*30}" ry="18" fill="#ffffff" opacity="0.08" filter="url(#mapBlurSoft)" />`;
            }

            terrainSvg.innerHTML += detailsHTML;

            // ---------- RUTAS PUNTEADAS ----------
            const connections = [
                ["emerald", "amber"], ["emerald", "rose"], ["emerald", "violet"],
                ["amber", "violet"], ["amber", "sky"], ["rose", "violet"], ["sky", "violet"]
            ];
            let routesHTML = "";
            connections.forEach(([a, b]) => {
                const pa = toMapCoords(MAP_POSITIONS[a]);
                const pb = toMapCoords(MAP_POSITIONS[b]);
                routesHTML += `<line x1="${pa.x}" y1="${pa.y}" x2="${pb.x}" y2="${pb.y}" stroke="#fde9c2" stroke-width="2" stroke-dasharray="2 8" stroke-linecap="round" opacity="0.5" />`;
            });
            routesSvg.innerHTML = routesHTML;

            mapBackgroundDrawn = true;
        }


