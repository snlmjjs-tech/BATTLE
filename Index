        /*************************************************************
         * H. INTERFAZ Y ACTUALIZACIONES DE RÁNKING
         *************************************************************/
        function updateUI() {
            const activeCastle = gameState.castles[gameState.currentTurn];
            const pName = document.getElementById("active-player-name");
            pName.innerText = activeCastle.name;
            pName.className = `text-2xl md:text-3xl font-medieval tracking-wide ${CASTLE_TAILWIND_COLORS[activeCastle.color].accent}`;

            const bonusBtn = document.getElementById("bonus-btn");
            if (activeCastle.bonusCooldown > 0) {
                bonusBtn.disabled = true;
                bonusBtn.classList.add("opacity-40", "cursor-not-allowed");
                bonusBtn.classList.remove("opacity-25");
                bonusBtn.innerHTML = `🎁 EN ${activeCastle.bonusCooldown} TURNO${activeCastle.bonusCooldown > 1 ? 'S' : ''}`;
            } else {
                bonusBtn.disabled = false;
                bonusBtn.classList.remove("opacity-25", "opacity-40", "cursor-not-allowed");
                bonusBtn.innerHTML = "🎁 COFRE DE RECURSOS";
            }

            // Actualizar Ránking Lateral
            const sidebar = document.getElementById("sidebar-leaderboard");
            sidebar.innerHTML = "";

            const sorted = [...gameState.castles].sort((a, b) => b.hp - a.hp);
            const highestHp = sorted[0].hp;

            sorted.forEach((castle, index) => {
                const colorConfig = CASTLE_TAILWIND_COLORS[castle.color];
                const isLeader = castle.hp === highestHp && castle.hp > 0;
                
                const item = document.createElement("div");
                item.className = `flex items-center justify-between p-2 rounded-lg border bg-stone-900/60 ${castle.destroyed ? 'border-red-950/20 opacity-35' : 'border-purple-950/20'}`;
                item.innerHTML = `
                    <div class="flex items-center gap-2 truncate">
                        <span class="text-xs font-bold text-stone-500">#${index + 1}</span>
                        <div class="w-2.5 h-2.5 rounded-full" style="background-color: ${colorConfig.hex}"></div>
                        <span class="text-xs font-semibold text-stone-200 truncate ${castle.destroyed ? 'line-through text-stone-500' : ''}">
                            ${castle.name}
                        </span>
                        ${isLeader && !castle.destroyed ? '<span class="text-[9px] text-yellow-500 font-bold animate-pulse">LÍDER</span>' : ''}
                    </div>
                    <div class="flex items-center gap-1.5 text-xs text-stone-400 font-medieval">
                        <span>❤️ ${castle.hp}</span>
                        <span>🛡️ ${castle.shield}</span>
                    </div>
                `;
                sidebar.appendChild(item);
            });

            // Cuadrícula de preguntas
            const qGrid = document.getElementById("questions-used-grid");
            qGrid.innerHTML = "";
            for (let i = 1; i <= 30; i++) {
                const isUsed = gameState.usedQuestions.includes(i);
                const cell = document.createElement("div");
                cell.className = `p-0.5 rounded text-[9px] font-bold ${isUsed ? 'bg-rose-950/70 text-rose-500 border border-rose-900/20' : 'bg-purple-950/70 text-purple-400 border border-purple-900/20'}`;
                cell.innerText = i;
                qGrid.appendChild(cell);
            }

            drawCastles();
        }

        function logAction(msg, type = 'info') {
            const container = document.getElementById("battle-log");
            const entry = document.createElement("div");
            
            let color = "text-stone-400";
            if (type === 'success') color = "text-emerald-400";
            if (type === 'danger') color = "text-rose-400";
            if (type === 'warning') color = "text-amber-400";
            if (type === 'bonus') color = "text-purple-400";

            entry.className = `${color} border-b border-stone-900/40 pb-1`;
            entry.innerHTML = `<span class="text-stone-600 font-bold">[${new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit'})}]</span> ${msg}`;
            
            container.appendChild(entry);
            container.scrollTop = container.scrollHeight;
            
            gameState.log.push({ msg, type, time: Date.now() });
            saveGameState();
        }


        /*************************************************************
         * I. FLUJO DE JUEGO & ALMACENAMIENTO DINÁMICO
         *************************************************************/
        window.onload = function() {
            // Generación de inputs
            const container = document.getElementById("setup-castles-list");
            container.innerHTML = "";
            for (let i = 0; i < 5; i++) {
                const colorConfig = CASTLE_TAILWIND_COLORS[CASTLE_COLORS[i]];
                container.innerHTML += `
                    <div class="flex items-center gap-3">
                        <span class="text-2xl">🏰</span>
                        <div class="w-full">
                            <label class="text-[10px] uppercase tracking-widest font-bold ${colorConfig.accent}">${colorConfig.name}</label>
                            <input id="input-castle-${i}" type="text" value="${DEFAULT_NAMES[i]}" maxlength="20" 
                                class="w-full bg-amber-50/95 border-2 border-amber-950/30 rounded-lg px-3 py-1.5 text-stone-900 font-semibold focus:border-amber-700 outline-none text-sm">
                        </div>
                    </div>
                `;
            }

            // Intento de recuperación seguro
            const loaded = SafeStorage.getItem(LOCAL_STORAGE_KEY);
            if (loaded) {
                try {
                    const parsed = JSON.parse(loaded);
                    if (parsed && parsed.castles && parsed.castles.length > 0) {
                        showFeedbackModal(
                            "💾 PARTIDA PREVIA DETECTADA", 
                            "Existe una batalla activa en los registros medievales de vuestro navegador. ¿Deseáis reanudar la campaña?",
                            [
                                { label: "REANUDAR CAMPANÑA", action: () => { loadSavedGame(); closeModal('modal-feedback'); } },
                                { label: "NUEVA PARTIDA", action: () => { SafeStorage.removeItem(LOCAL_STORAGE_KEY); closeModal('modal-feedback'); } }
                            ]
                        );
                    }
                } catch(e) {
                    SafeStorage.removeItem(LOCAL_STORAGE_KEY);
                }
            }
        };

        function startGame() {
            sound.init(); 
            sound.playClick();
            
            gameState.castles = [];
            for (let i = 0; i < 5; i++) {
                const nameInput = document.getElementById(`input-castle-${i}`).value.trim();
                gameState.castles.push({
                    name: nameInput || DEFAULT_NAMES[i],
                    color: CASTLE_COLORS[i],
                    hp: 5,
                    shield: 0,
                    hammer: 0,
                    superbomb: false,
                    destroyed: false,
                    bonusCooldown: 0
                });
            }

            gameState.timerEnabled = document.getElementById("timer-toggle").checked;
            gameState.currentTurn = 0;
            gameState.usedQuestions = [];
            gameState.status = "playing";
            gameState.log = [];
            gameState.kingMoods = ["idle", "idle", "idle", "idle", "idle"];

            document.getElementById("screen-setup").classList.add("hidden");
            document.getElementById("screen-game").classList.remove("hidden");
            
            logAction("⚔️ ¡Ha iniciado el asedio de los reinos! Demostrad vuestro conocimiento.", "warning");
            updateUI();
            saveGameState();
        }

        function nextTurn() {
            if (checkVictory()) return;

            let attempts = 0;
            do {
                gameState.currentTurn = (gameState.currentTurn + 1) % 5;
                attempts++;
            } while (gameState.castles[gameState.currentTurn].destroyed && attempts < 6);

            const upcomingCastle = gameState.castles[gameState.currentTurn];

            // El cofre de recursos se vuelve a habilitar tras 3 turnos propios desde su último uso
            if (upcomingCastle.bonusCooldown > 0) {
                upcomingCastle.bonusCooldown--;
                if (upcomingCastle.bonusCooldown === 0) {
                    logAction(`🎁 ¡El cofre de recursos de <strong class="text-white">${upcomingCastle.name}</strong> está disponible de nuevo!`, "bonus");
                }
            }

            gameState.kingMoods[gameState.currentTurn] = "idle";
            gameState.superBombActive = false; 

            logAction(`Siguiente turno: <strong class="text-white">${upcomingCastle.name}</strong>`, "info");
            updateUI();
            saveGameState();
        }

        function checkVictory() {
            const alive = gameState.castles.filter(c => !c.destroyed);
            if (alive.length === 1) {
                gameState.status = "victory";
                const winner = alive[0];
                const winnerIndex = gameState.castles.findIndex(c => c.name === winner.name);

                gameState.kingMoods[winnerIndex] = "victory";

                document.getElementById("screen-game").classList.add("hidden");
                document.getElementById("screen-victory").classList.remove("hidden");
                document.getElementById("victory-castle-name").innerText = winner.name;
                document.getElementById("victory-king-container").innerHTML = getKingSVG(winner.color, 'victory');

                sound.playFanfare();
                triggerConfetti();
                createFireworks();
                
                logAction(`👑 ¡${winner.name} HA CONQUISTADO EL TRONO ABSOLUTO!`, "success");
                SafeStorage.removeItem(LOCAL_STORAGE_KEY);
                return true;
            }
            return false;
        }

        function saveGameState() {
            SafeStorage.setItem(LOCAL_STORAGE_KEY, JSON.stringify(gameState));
        }

        function loadSavedGame() {
            const data = JSON.parse(SafeStorage.getItem(LOCAL_STORAGE_KEY));
            if (data) {
                gameState = data;
                document.getElementById("screen-setup").classList.add("hidden");
                document.getElementById("screen-game").classList.remove("hidden");
                document.getElementById("screen-victory").classList.add("hidden");
                
                if (!sound.muted) {
                    sound.startMusic();
                }

                logAction("💾 Campaña recuperada correctamente.", "success");
                updateUI();
            }
        }

        function triggerResetConfirm() {
            sound.playClick();
            showFeedbackModal(
                "⚔️ ¿ABANDONAR?",
                "¿Deseáis abandonar las fortalezas activas? La campaña actual se perderá en las arenas del tiempo.",
                [
                    { label: "SÍ, REINICIAR", action: () => { SafeStorage.removeItem(LOCAL_STORAGE_KEY); triggerResetGame(); } },
                    { label: "SEGUIR JUGANDO", action: () => closeModal('modal-feedback') }
                ]
            );
        }

        function triggerResetGame() {
            location.reload();
        }


        /*************************************************************
         * J. SISTEMA GRAMATICAL DE PREGUNTAS Y TEMPORIZADORES
         *************************************************************/
        function promptQuestionSelection() {
            sound.playClick();
            
            const grid = document.getElementById("pergaminos-grid-selection");
            grid.innerHTML = "";

            for (let i = 1; i <= 30; i++) {
                const isUsed = gameState.usedQuestions.includes(i);
                const btn = document.createElement("button");
                
                if (isUsed) {
                    btn.className = "p-3 bg-stone-900 border border-stone-850 text-stone-600 rounded-xl cursor-not-allowed text-xs font-bold font-medieval flex flex-col items-center justify-center shadow-inner";
                    btn.innerHTML = `<span>📜</span><span class="text-[9px]">X</span>`;
                    btn.disabled = true;
                } else {
                    btn.className = "rpg-btn p-3 rounded-xl text-sm font-bold font-medieval flex flex-col items-center justify-center text-white shadow-md";
                    btn.innerHTML = `<span>📜</span><span>${i}</span>`;
                    btn.setAttribute("onclick", `selectQuestion(${i})`);
                }
                grid.appendChild(btn);
            }

            openModal('modal-pergaminos');
        }

        function selectQuestion(num) {
            sound.playClick();
            closeModal('modal-pergaminos');

            if (gameState.usedQuestions.includes(num)) {
                showFeedbackModal("❌ PERGAMINO AGOTADO", "Este manuscrito ya ha sido descifrado.", [
                    { label: "ENTENDIDO", action: () => { closeModal('modal-feedback'); promptQuestionSelection(); } }
                ]);
                return;
            }

            gameState.selectedQuestionNum = num;
            
            const q = VERBOS_PREGUNTAS.find(item => item.id === num);
            if (!q) return;

            gameState.activeQuestion = q;
            
            document.getElementById("question-index-label").innerText = `MANUSCRITO DE ASEGURACIÓN #${num}`;
            document.getElementById("question-verb").innerText = q.past;

            const mixedOptions = [...q.options].sort(() => Math.random() - 0.5);
            const container = document.getElementById("alternatives-container");
            container.innerHTML = "";

            mixedOptions.forEach(opt => {
                const optBtn = document.createElement("button");
                optBtn.className = "w-full py-3.5 px-5 bg-stone-900 hover:bg-stone-850 border-2 border-stone-700 hover:border-amber-500 rounded-xl text-left text-base font-medieval text-stone-200 flex justify-between items-center transition duration-150 active:scale-95 shadow-md";
                optBtn.innerHTML = `<span>${opt}</span> <span class="opacity-30">🛡️</span>`;
                optBtn.setAttribute("onclick", `submitAnswer('${opt}')`);
                container.appendChild(optBtn);
            });

            openModal('modal-pregunta');

            if (gameState.timerEnabled) {
                startTimer();
            } else {
                document.getElementById("timer-bar-container").classList.add("hidden");
                document.getElementById("countdown-label").innerText = "Sin límite";
            }
        }

        function startTimer() {
            document.getElementById("timer-bar-container").classList.remove("hidden");
            gameState.timerRemaining = 15;
            const bar = document.getElementById("timer-bar");
            const label = document.getElementById("countdown-label");

            bar.style.width = "100%";
            label.innerText = `⏱️ ${gameState.timerRemaining}s`;

            clearInterval(gameState.timerInterval);
            gameState.timerInterval = setInterval(() => {
                gameState.timerRemaining--;
                label.innerText = `⏱️ ${gameState.timerRemaining}s`;
                bar.style.width = `${(gameState.timerRemaining / 15) * 100}%`;

                if (gameState.timerRemaining <= 0) {
                    clearInterval(gameState.timerInterval);
                    handleTimeout();
                }
            }, 1000);
        }

        function handleTimeout() {
            sound.playIncorrect();
            closeModal('modal-pregunta');
            
            const activeCastle = gameState.castles[gameState.currentTurn];
            gameState.kingMoods[gameState.currentTurn] = "incorrect"; 
            gameState.usedQuestions.push(gameState.selectedQuestionNum);

            logAction(`⏳ ¡Tiempo agotado para <strong class="text-white">${activeCastle.name}</strong>! Se le escapó la oportunidad.`, "danger");

            showFeedbackModal("⏳ TIEMPO AGOTADO", "El tiempo de asedio se ha consumido. Vuestras tropas pierden la iniciativa.", [
                { label: "Pasar Turno", action: () => { closeModal('modal-feedback'); nextTurn(); } }
            ]);
        }

        function submitAnswer(selected) {
            clearInterval(gameState.timerInterval);
            closeModal('modal-pregunta');

            const q = gameState.activeQuestion;
            const activeCastle = gameState.castles[gameState.currentTurn];
            gameState.usedQuestions.push(gameState.selectedQuestionNum);

            if (selected === q.correct) {
                sound.playCorrect();
                gameState.kingMoods[gameState.currentTurn] = "correct"; 
                logAction(`✅ <strong class="text-white">${activeCastle.name}</strong> dominó el verbo #${gameState.selectedQuestionNum} (${q.past} -> ${q.correct}).`, "success");
                
                if (activeCastle.superbomb) {
                    gameState.superBombActive = true;
                    activeCastle.superbomb = false; 
                }

                gameState.status = "target_selection";
                updateUI();
                
                showFeedbackModal(
                    "🔥 ¡PREPARAD CATAPULTA!",
                    "¡Verbo correcto! Haced clic directo sobre el reino enemigo que deseáis bombardear en el mapa.",
                    [{ label: "ELEGIR OBJETIVO EN EL MAPA", action: () => closeModal('modal-feedback') }]
                );

            } else {
                sound.playIncorrect();
                gameState.kingMoods[gameState.currentTurn] = "incorrect"; 
                logAction(`❌ <strong class="text-white">${activeCastle.name}</strong> erró el manuscrito #${gameState.selectedQuestionNum} (${selected}). Era ${q.correct}.`, "danger");

                showFeedbackModal("❌ TRADUCCIÓN FALLIDA", `El infinitivo correcto de <strong>${q.past}</strong> es <strong>${q.correct}</strong>. Vuestros soldados se confunden y pierden el asedio.`, [
                    { label: "Siguiente Turno", action: () => { closeModal('modal-feedback'); nextTurn(); } }
                ]);
            }
        }


        /*************************************************************
         * K. LANZAMIENTO, COLISIONES Y RESOLUCIÓN DE DAÑOS
         *************************************************************/
        function executeCatapultAttack(targetIndex) {
            sound.playClick();
            gameState.status = "playing"; 

            const attackerIndex = gameState.currentTurn;
            const attacker = gameState.castles[attackerIndex];
            const target = gameState.castles[targetIndex];

            const cardAttacker = document.getElementById(`castle-card-${attackerIndex}`).getBoundingClientRect();
            const cardTarget = document.getElementById(`castle-card-${targetIndex}`).getBoundingClientRect();

            const startX = cardAttacker.left + cardAttacker.width / 2;
            const startY = cardAttacker.top + cardAttacker.height / 2;
            const targetX = cardTarget.left + cardTarget.width / 2;
            const targetY = cardTarget.top + cardTarget.height / 2;

            logAction(`☄️ <strong class="text-white">${attacker.name}</strong> lanza asalto de catapulta hacia <strong class="text-white">${target.name}</strong>.`, "warning");

            projectiles.push(new Projectile(startX, startY, targetX, targetY, () => {
                const isSuper = gameState.superBombActive;
                createExplosion(targetX, targetY, isSuper);
                applyAttackDamage(targetIndex, isSuper);
                gameState.superBombActive = false; 
            }));

            updateUI();
        }

        function applyAttackDamage(targetIndex, isSuper = false) {
            const target = gameState.castles[targetIndex];
            const damageToDeal = isSuper ? 2 : 1;

            gameState.kingMoods[targetIndex] = "hit";

            setTimeout(() => {
                if (target.shield > 0) {
                    target.shield--;
                    sound.playShield();
                    gameState.kingMoods[targetIndex] = "shield"; 
                    logAction(`🛡️ ¡El Escudo rúnico de <strong class="text-white">${target.name}</strong> neutralizó el impacto!`, "success");
                    
                    showFeedbackModal("🛡️ IMPACTO ABSORBIDO", `El escudo protector de <strong>${target.name}</strong> bloqueó la bomba con éxito.`, [
                        { label: "Continuar", action: () => { closeModal('modal-feedback'); nextTurn(); } }
                    ]);
                } else {
                    target.hp -= damageToDeal;
                    if (target.hp < 0) target.hp = 0;

                    logAction(`💥 ¡Brecha lograda! <strong class="text-white">${target.name}</strong> sufre ${damageToDeal} de daño estructural.`, "danger");

                    if (target.hp <= 0) {
                        target.destroyed = true;
                        gameState.kingMoods[targetIndex] = "destroyed"; 
                        logAction(`🏰☠️ ¡LA CIUDADELA DE <strong class="text-white">${target.name}</strong> HA SIDO ASOLADA!`, "danger");
                        
                        showFeedbackModal("💥 ¡REINO ASOLADO!", `El castillo de <strong>${target.name}</strong> ha quedado reducido a escombros 3D. Sus tropas huyen.`, [
                            { label: "Continuar", action: () => { closeModal('modal-feedback'); nextTurn(); } }
                        ]);
                    } else {
                        setTimeout(() => {
                            if (!target.destroyed) gameState.kingMoods[targetIndex] = "idle";
                            updateUI();
                        }, 1800);

                        showFeedbackModal("💥 IMPACTO DIRECTO", `La fortaleza de <strong>${target.name}</strong> sufre graves averías estructurales (-${damageToDeal} HP).`, [
                            { label: "Continuar", action: () => { closeModal('modal-feedback'); nextTurn(); } }
                        ]);
                    }
                }
                updateUI();
                saveGameState();
            }, 500);
        }


        /*************************************************************
         * L. APERTURA DE COFRES DE BONIFICACIÓN 3D
         *************************************************************/
        function openBonusChestSelection() {
            sound.playClick();
            
            const rewardsPool = [
                { type: 'shield', icon: '🛡️', title: 'Escudo Rúnico', desc: 'Anula por completo el próximo impacto enemigo.' },
                { type: 'shield', icon: '🛡️', title: 'Escudo Rúnico', desc: 'Anula por completo el próximo impacto enemigo.' },
                { type: 'shield', icon: '🛡️', title: 'Escudo Rúnico', desc: 'Anula por completo el próximo impacto enemigo.' },
                { type: 'shield', icon: '🛡️', title: 'Escudo Rúnico', desc: 'Anula por completo el próximo impacto enemigo.' },
                { type: 'hammer', icon: '🔨', title: 'Martillo Constructor', desc: 'Restaura 1 punto de vida a vuestro bastión.' },
                { type: 'hammer', icon: '🔨', title: 'Martillo Constructor', desc: 'Restaura 1 punto de vida a vuestro bastión.' },
                { type: 'superbomb', icon: '💣', title: 'Super Bomba', desc: 'Vuestro próximo disparo correcto infligirá daño doble.' },
                { type: 'empty', icon: '💨', title: 'Viento Vacío', desc: 'Este cofre solo contenía aire húmedo de las mazmorras.' },
                { type: 'empty', icon: '💨', title: 'Viento Vacío', desc: 'Este cofre solo contenía aire húmedo de las mazmorras.' },
                { type: 'empty', icon: '💨', title: 'Viento Vacío', desc: 'Este cofre solo contenía aire húmedo de las mazmorras.' }
            ];

            gameState.chestRewards = rewardsPool.sort(() => Math.random() - 0.5);

            const container = document.getElementById("chests-container");
            container.innerHTML = "";

            for (let i = 0; i < 10; i++) {
                const card = document.createElement("div");
                card.className = "chest-card h-28 cursor-pointer relative";
                card.setAttribute("onclick", `flipChest(${i})`);
                
                card.innerHTML = `
                    <div class="chest-inner w-full h-full relative" id="chest-inner-${i}">
                        <!-- Cara Frontal (Cerrado 3D) -->
                        <div class="chest-front absolute inset-0 bg-gradient-to-b from-amber-900 to-amber-950 border-2 border-amber-600 rounded-xl flex flex-col items-center justify-center text-white p-2 shadow-2xl hover:border-yellow-400 transition-all">
                            <!-- Cofre dibujado en perspectiva -->
                            <span class="text-4xl filter drop-shadow-[0_4px_6px_rgba(0,0,0,0.6)]">📦</span>
                            <span class="text-[10px] font-medieval mt-1 text-amber-300">TESORO ${i+1}</span>
                        </div>
                        <!-- Cara Trasera (Revelado) -->
                        <div class="chest-back absolute inset-0 bg-gradient-to-b from-stone-900 to-stone-950 border-2 border-purple-500 rounded-xl flex flex-col items-center justify-center text-white p-1 text-center shadow-inner">
                            <span class="text-3xl filter drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]" id="chest-back-icon-${i}">❓</span>
                            <span class="text-[9px] font-bold text-purple-300 truncate w-full mt-1" id="chest-back-title-${i}">Item</span>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            }

            openModal('modal-bonus');
        }

        function flipChest(index) {
            sound.playClick();
            
            const activeCastle = gameState.castles[gameState.currentTurn];
            activeCastle.bonusCooldown = 3;

            const allChests = document.querySelectorAll(".chest-card");
            allChests.forEach(card => card.removeAttribute("onclick"));

            const reward = gameState.chestRewards[index];
            
            document.getElementById(`chest-back-icon-${index}`).innerText = reward.icon;
            document.getElementById(`chest-back-title-${index}`).innerText = reward.title;
            document.getElementById(`chest-inner-${index}`).parentElement.classList.add("flipped");

            setTimeout(() => {
                applyBonusReward(reward);
                closeModal('modal-bonus');
            }, 1400);
        }

        function applyBonusReward(reward) {
            const activeCastle = gameState.castles[gameState.currentTurn];

            switch (reward.type) {
                case 'shield':
                    activeCastle.shield++;
                    sound.playShield();
                    logAction(`🎁 ¡<strong class="text-white">${activeCastle.name}</strong> obtuvo un 🛡️ ${reward.title}!`, "bonus");
                    showFeedbackModal("🛡️ PROTECCIÓN OBTENIDA", "Se ha erigido un escudo mágico sobre vuestra torre para bloquear el próximo disparo.", [
                        { label: "Excelente", action: () => { closeModal('modal-feedback'); updateUI(); } }
                    ]);
                    break;

                case 'hammer':
                    sound.playRepair();
                    if (activeCastle.hp < 5) {
                        activeCastle.hp++;
                        logAction(`🎁 ¡<strong class="text-white">${activeCastle.name}</strong> reparó sus murallas con un 🔨 ${reward.title}! Restaura 1 HP.`, "bonus");
                        showFeedbackModal("🔨 RECONSTRUCCIÓN 3D", "Constructores del imperio han reparado 1 punto de daño real en vuestros muros.", [
                            { label: "Estupendo", action: () => { closeModal('modal-feedback'); updateUI(); } }
                        ]);
                    } else {
                        logAction(`🎁 <strong class="text-white">${activeCastle.name}</strong> encontró un 🔨 ${reward.title}, pero sus defensas estaban completas. No tuvo efecto.`, "warning");
                        showFeedbackModal("🔨 MARTILLO SIN EFECTO", "Vuestras murallas se encuentran en estado óptimo. El martillo no ha surtido efecto.", [
                            { label: "De acuerdo", action: () => { closeModal('modal-feedback'); updateUI(); } }
                        ]);
                    }
                    break;

                case 'superbomb':
                    activeCastle.superbomb = true;
                    sound.playClick();
                    logAction(`🎁 ¡<strong class="text-white">${activeCastle.name}</strong> armó una 💣 Súper Bomba de asedio!`, "bonus");
                    showFeedbackModal("💣 ARMAMENTO PESADO", "¡Letal! Vuestro siguiente asalto correcto causará daño doble (2 HP) e impacto masivo.", [
                        { label: "¡A Disparar!", action: () => { closeModal('modal-feedback'); updateUI(); } }
                    ]);
                    break;

                case 'empty':
                    sound.playIncorrect();
                    logAction(`💨 <strong class="text-white">${activeCastle.name}</strong> abrió un cofre vacío.`, "info");
                    showFeedbackModal("💨 COFRE VACÍO", "La fortuna os ha ignorado esta vez. No habéis encontrado nada de valor en la caja.", [
                        { label: "Continuar", action: () => { closeModal('modal-feedback'); updateUI(); } }
                    ]);
                    break;
            }
        }


        /*************************************************************
         * M. CONTROL DE VENTANAS MODALES DINÁMICAS
         *************************************************************/
        function openModal(id) {
            document.getElementById(id).classList.remove("hidden");
        }

        function closeModal(id) {
            document.getElementById(id).classList.add("hidden");
        }

        function showFeedbackModal(title, message, buttons = []) {
            document.getElementById("feedback-title").innerHTML = title;
            document.getElementById("feedback-message").innerHTML = message;

            const btnContainer = document.getElementById("feedback-buttons-container");
            btnContainer.innerHTML = "";

            if (buttons.length === 0) {
                buttons.push({ label: "ENTENDIDO", action: () => closeModal('modal-feedback') });
            }

            buttons.forEach(btnConfig => {
                const btn = document.createElement("button");
                btn.className = "rpg-btn py-2.5 px-5 text-xs font-medieval text-white font-bold rounded-lg tracking-wider shadow-md";
                btn.innerText = btnConfig.label;
                btn.onclick = btnConfig.action;
                btnContainer.appendChild(btn);
            });

            openModal('modal-feedback');
        }
    </script>
</body>
