        let mapBackgroundDrawn = false;

        function toMapCoords(pct) {
            return { x: pct.x * 10, y: pct.y * 6.25 };
        }

        function drawMapBackground() {
            const terrainSvg = document.getElementById("map-terrain");
            const routesSvg = document.getElementById("map-routes");
            if (!terrainSvg || !routesSvg) return;

            // Generador determinista de "ruido" para variar formas sin que cambien entre redraws
            function noise(seed) {
                const x = Math.sin(seed * 12.9898) * 43758.5453;
                return x - Math.floor(x);
            }

            // Crea un contorno de isla orgánico (blob) alrededor de un centro
            function islandPath(cx, cy, baseR, seedOffset, irregularity = 0.3) {
                const points = 14;
                let d = "";
                for (let i = 0; i <= points; i++) {
                    const angle = (i / points) * Math.PI * 2;
                    const n = noise(i * 7.31 + seedOffset);
                    const r = baseR * (1 - irregularity / 2 + n * irregularity);
                    const x = cx + Math.cos(angle) * r;
                    const y = cy + Math.sin(angle) * r * 0.78;
                    d += (i === 0 ? `M ${x},${y}` : ` L ${x},${y}`);
                }
                return d + " Z";
            }

            let terrainHTML = `
