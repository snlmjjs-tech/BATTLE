        class Particle {
            constructor(x, y, color, type = 'smoke') {
                this.x = x;
                this.y = y;
                this.color = color;
                this.type = type;
                this.vx = (Math.random() - 0.5) * (type === 'fireworks' ? 14 : 5);
                this.vy = (Math.random() - 0.5) * (type === 'fireworks' ? 14 : 5) - (type === 'smoke' || type === 'fire' ? 2.5 : 0);
                this.alpha = 1;
                this.size = Math.random() * (type === 'smoke' ? 22 : type === 'fire' ? 16 : type === 'fireworks' ? 6 : 4) + 2;
                this.decay = Math.random() * 0.018 + 0.012;
                this.gravity = type === 'confetti' || type === 'fireworks' ? 0.15 : 0;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;
                this.vy += this.gravity;
                this.alpha -= this.decay;
                if (this.alpha < 0) this.alpha = 0;
            }

            draw() {
                ctx.save();
                ctx.globalAlpha = this.alpha;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                if (this.type === 'confetti') {
                    ctx.fillRect(this.x, this.y, this.size, this.size * 1.5);
                } else {
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fill();
                }
                ctx.restore();
            }
        }

        class Projectile {
            constructor(startX, startY, targetX, targetY, callback) {
                this.startX = startX;
                this.startY = startY;
                this.targetX = targetX;
                this.targetY = targetY;
                this.progress = 0;
                this.speed = 0.016; 
                this.height = 200; 
                this.callback = callback;
            }

            update() {
                this.progress += this.speed;
                if (this.progress >= 1) {
                    this.progress = 1;
                    this.callback();
                    return false;
                }
                
                if (Math.random() < 0.6) {
                    const pos = this.getPosition();
                    particles.push(new Particle(pos.x, pos.y, 'rgba(140, 130, 120, 0.45)', 'smoke'));
                    particles.push(new Particle(pos.x, pos.y, 'rgba(255, 140, 0, 0.9)', 'fire'));
                }
                return true;
            }

            getPosition() {
                const x = this.startX + (this.targetX - this.startX) * this.progress;
                const arc = this.height * Math.sin(Math.PI * this.progress);
                const y = this.startY + (this.targetY - this.startY) * this.progress - arc;
                return { x, y };
            }

            draw() {
                const pos = this.getPosition();
                ctx.save();
                
                // Sombra realista
                ctx.beginPath();
                ctx.arc(pos.x, pos.y + 20, 12, 0, Math.PI * 2);
                ctx.fillStyle = "rgba(0,0,0,0.3)";
                ctx.fill();

                // Bola de Catapulta en 3D (con degradado radial)
                let grad = ctx.createRadialGradient(pos.x - 3, pos.y - 3, 2, pos.x, pos.y, 10);
                grad.addColorStop(0, '#78716c');
                grad.addColorStop(0.5, '#44403c');
                grad.addColorStop(1, '#1c1917');

                ctx.beginPath();
                ctx.arc(pos.x, pos.y, 10, 0, Math.PI * 2);
                ctx.fillStyle = grad;
                ctx.fill();

                // Chispa de mecha encendida
                if (Math.random() < 0.7) {
                    ctx.beginPath();
                    ctx.arc(pos.x + 8, pos.y - 8, Math.random() * 4 + 3, 0, Math.PI * 2);
                    ctx.fillStyle = "#fbbf24";
                    ctx.fill();
                }

                ctx.restore();
            }
        }

        function gameLoop() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            if (screenShakeAmount > 0) {
                const dx = (Math.random() - 0.5) * screenShakeAmount;
                const dy = (Math.random() - 0.5) * screenShakeAmount;
                document.getElementById("game-container").style.transform = `translate(${dx}px, ${dy}px)`;
                screenShakeAmount -= 0.8;
            } else {
                document.getElementById("game-container").style.transform = `none`;
            }

            projectiles = projectiles.filter(p => {
                const active = p.update();
                if (active) p.draw();
                return active;
            });

            particles = particles.filter(p => {
                p.update();
                p.draw();
                return p.alpha > 0;
            });

            requestAnimationFrame(gameLoop);
        }
        gameLoop();

        function createExplosion(x, y, isSuper = false) {
            sound.playExplosion(isSuper);
            screenShakeAmount = isSuper ? 30 : 15;
            
            const numParticles = isSuper ? 100 : 50;
            const colors = ['#f43f5e', '#ff781f', '#fcd34d', '#57534e', '#1c1917'];

            for (let i = 0; i < numParticles; i++) {
                const color = colors[Math.floor(Math.random() * colors.length)];
                particles.push(new Particle(x, y, color, Math.random() < 0.65 ? 'fire' : 'smoke'));
            }

            for (let i = 0; i < 15; i++) {
                particles.push(new Particle(x, y, '#ffffff', 'spark'));
            }
        }

        function createFireworks() {
            if (gameState.status !== 'victory') return;
            const colors = ['#fbbf24', '#f43f5e', '#3b82f6', '#10b981', '#c084fc'];
            
            const run = () => {
                if (gameState.status !== 'victory') return;
                const x = Math.random() * canvas.width;
                const y = Math.random() * (canvas.height * 0.5);
                const color = colors[Math.floor(Math.random() * colors.length)];
                
                sound.playCorrect();
                for (let i = 0; i < 35; i++) {
                    particles.push(new Particle(x, y, color, 'fireworks'));
                }
                setTimeout(run, Math.random() * 600 + 400);
            };
            run();
        }

        function triggerConfetti() {
            for (let i = 0; i < 120; i++) {
                setTimeout(() => {
                    if (gameState.status !== 'victory') return;
                    const x = Math.random() * canvas.width;
                    const y = -10;
                    const color = `hsl(${Math.random() * 360}, 100%, 55%)`;
                    particles.push(new Particle(x, y, color, 'confetti'));
                }, i * 35);
            }
        }


