    <script>
        /*************************************************************
         * A. MANEJADOR SEGURO DE ALMACENAMIENTO (SafeStorage)
         * Previene bloqueos del hilo JS si el navegador bloquea cookies/almacenamiento en iframes
         *************************************************************/
        const SafeStorage = {
            fallback: {},
            getItem(key) {
                try {
                    return localStorage.getItem(key);
                } catch (e) {
                    return this.fallback[key] || null;
                }
            },
            setItem(key, value) {
                try {
                    localStorage.setItem(key, value);
                } catch (e) {
                    this.fallback[key] = value;
                }
            },
            removeItem(key) {
                try {
                    localStorage.removeItem(key);
                } catch (e) {
                    delete this.fallback[key];
                }
            }
        };

        /*************************************************************
         * B. MOTOR DE SONIDO (SINTETIZADO - Web Audio API NATIVO)
         * Soporte 100% Offline y dinámico.
         *************************************************************/
        class SoundEngine {
            constructor() {
                this.ctx = null;
                this.muted = true;
                this.volume = 0.5;
                this.musicPlaying = false;
                this.melodyTimer = null;
                this.currentTempo = 115; // BPM medieval pausado
                this.step = 0;
            }

            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
                if (this.ctx && this.ctx.state === 'suspended') {
                    this.ctx.resume();
                }
            }

            playClick() {
                if (this.muted) return;
                this.init();
                let osc = this.ctx.createOscillator();
                let gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(320, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(650, this.ctx.currentTime + 0.08);
                
                gain.gain.setValueAtTime(this.volume * 0.25, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.08);
                
                osc.start();
                osc.stop(this.ctx.currentTime + 0.08);
            }

            playCorrect() {
                if (this.muted) return;
                this.init();
                const now = this.ctx.currentTime;
                const notes = [523.25, 659.25, 783.99, 1046.50];
                notes.forEach((freq, idx) => {
                    let osc = this.ctx.createOscillator();
                    let gain = this.ctx.createGain();
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);
                    
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(freq, now + idx * 0.07);
                    gain.gain.setValueAtTime(0, now + idx * 0.07);
                    gain.gain.linearRampToValueAtTime(this.volume * 0.35, now + idx * 0.07 + 0.02);
                    gain.gain.exponentialRampToValueAtTime(0.01, now + idx * 0.07 + 0.25);
                    
                    osc.start(now + idx * 0.07);
                    osc.stop(now + idx * 0.07 + 0.25);
                });
            }

            playIncorrect() {
                if (this.muted) return;
                this.init();
                const now = this.ctx.currentTime;
                let osc = this.ctx.createOscillator();
                let gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(180, now);
                osc.frequency.linearRampToValueAtTime(70, now + 0.35);
                
                gain.gain.setValueAtTime(this.volume * 0.35, now);
                gain.gain.exponentialRampToValueAtTime(0.01, now + 0.35);
                
                osc.start();
                osc.stop(now + 0.35);
            }

            playExplosion(isSuper = false) {
                if (this.muted) return;
                this.init();
                const now = this.ctx.currentTime;
                
                const bufferSize = this.ctx.sampleRate * (isSuper ? 1.5 : 0.8);
                const buffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
                const data = buffer.getChannelData(0);
                for (let i = 0; i < bufferSize; i++) {
                    data[i] = Math.random() * 2 - 1;
                }
                
                let noise = this.ctx.createBufferSource();
                noise.buffer = buffer;
                
                let filter = this.ctx.createBiquadFilter();
                filter.type = 'lowpass';
                filter.frequency.setValueAtTime(isSuper ? 200 : 400, now);
                filter.frequency.exponentialRampToValueAtTime(30, now + (isSuper ? 1.2 : 0.6));
                
                let gain = this.ctx.createGain();
                gain.gain.setValueAtTime(this.volume * 1.2, now);
                gain.gain.exponentialRampToValueAtTime(0.01, now + (isSuper ? 1.4 : 0.75));
                
                noise.connect(filter);
                filter.connect(gain);
                gain.connect(this.ctx.destination);
                
                noise.start(now);
                noise.stop(now + (isSuper ? 1.4 : 0.75));
            }

            playShield() {
                if (this.muted) return;
                this.init();
                const now = this.ctx.currentTime;
                let osc = this.ctx.createOscillator();
                let gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                
                osc.type = 'sine';
                osc.frequency.setValueAtTime(800, now);
                osc.frequency.linearRampToValueAtTime(1500, now + 0.25);
                
                gain.gain.setValueAtTime(this.volume * 0.45, now);
                gain.gain.exponentialRampToValueAtTime(0.01, now + 0.25);
                
                osc.start();
                osc.stop(now + 0.25);
            }

            playRepair() {
                if (this.muted) return;
                this.init();
                const now = this.ctx.currentTime;
                for (let i = 0; i < 3; i++) {
                    let osc = this.ctx.createOscillator();
                    let gain = this.ctx.createGain();
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);
                    
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(280 + i * 110, now + i * 0.12);
                    
                    gain.gain.setValueAtTime(0, now + i * 0.12);
                    gain.gain.linearRampToValueAtTime(this.volume * 0.35, now + i * 0.12 + 0.02);
                    gain.gain.exponentialRampToValueAtTime(0.01, now + i * 0.12 + 0.1);
                    
                    osc.start(now + i * 0.12);
                    osc.stop(now + i * 0.12 + 0.1);
                }
            }

            playFanfare() {
                if (this.muted) return;
                this.init();
                const now = this.ctx.currentTime;
                const notes = [
                    { f: 293.66, d: 0.15 },
                    { f: 349.23, d: 0.15 },
                    { f: 440.00, d: 0.15 },
                    { f: 587.33, d: 0.5 }
                ];
                
                notes.forEach((note, index) => {
                    let osc = this.ctx.createOscillator();
                    let gain = this.ctx.createGain();
                    
                    osc.type = 'sawtooth';
                    let filter = this.ctx.createBiquadFilter();
                    filter.type = 'lowpass';
                    filter.frequency.setValueAtTime(1000, now);
                    
                    osc.connect(filter);
                    filter.connect(gain);
                    gain.connect(this.ctx.destination);

                    const startTime = now + index * 0.18;
                    osc.frequency.setValueAtTime(note.f, startTime);
                    gain.gain.setValueAtTime(0, startTime);
                    gain.gain.linearRampToValueAtTime(this.volume * 0.35, startTime + 0.02);
                    gain.gain.exponentialRampToValueAtTime(0.01, startTime + note.d);
                    
                    osc.start(startTime);
                    osc.stop(startTime + note.d);
                });
            }

            startMusic() {
                if (this.musicPlaying) return;
                this.init();
                this.musicPlaying = true;

                // Escala A Dorian (modo medieval clásico): A B C D E F# G
                const scale = [220.00, 246.94, 261.63, 293.66, 329.63, 369.99, 392.00, 440.00];
                // Melodía con saltos modales y reposos, estilo cantiga/danza antigua
                const melody = [
                    0, 2, 3, 4, 3, 2, 0, 2,
                    4, 6, 5, 4, 3, 2, 1, 0,
                    0, 3, 5, 7, 5, 3, 2, 0,
                    2, 4, 3, 2, 0, -1, 0, -1
                ];

                this.currentTempo = 86; // Más pausado y solemne
                const stepDuration = 60 / this.currentTempo;

                // Dron grave de "viola de rueda" sostenido bajo toda la melodía
                const droneOsc1 = this.ctx.createOscillator();
                const droneOsc2 = this.ctx.createOscillator();
                const droneGain = this.ctx.createGain();
                const droneFilter = this.ctx.createBiquadFilter();
                droneFilter.type = 'lowpass';
                droneFilter.frequency.value = 500;
                droneOsc1.type = 'sawtooth';
                droneOsc2.type = 'sawtooth';
                droneOsc1.frequency.value = scale[0] / 2;
                droneOsc2.frequency.value = (scale[0] / 2) * 1.005; // leve desafinación para textura de cuerda
                droneOsc1.connect(droneFilter);
                droneOsc2.connect(droneFilter);
                droneFilter.connect(droneGain);
                droneGain.connect(this.ctx.destination);
                droneGain.gain.value = 0;
                droneGain.gain.linearRampToValueAtTime(this.volume * 0.08, this.ctx.currentTime + 1.5);
                droneOsc1.start();
                droneOsc2.start();
                this.droneOsc1 = droneOsc1;
                this.droneOsc2 = droneOsc2;
                this.droneGain = droneGain;

                const playStep = () => {
                    if (!this.musicPlaying || this.muted) return;

                    const now = this.ctx.currentTime;
                    const scaleIndex = melody[this.step % melody.length];

                    // Nota tipo "pulsada" (laúd/arpa): sawtooth + filtro paso bajo con decaimiento rápido
                    if (scaleIndex >= 0) {
                        const freq = scaleIndex >= 7 ? scale[scaleIndex % 8] * 2 : scale[scaleIndex];

                        let osc = this.ctx.createOscillator();
                        let filt = this.ctx.createBiquadFilter();
                        let gain = this.ctx.createGain();
                        osc.connect(filt);
                        filt.connect(gain);
                        gain.connect(this.ctx.destination);

                        osc.type = 'sawtooth';
                        filt.type = 'lowpass';
                        filt.frequency.setValueAtTime(2200, now);
                        filt.frequency.exponentialRampToValueAtTime(500, now + stepDuration * 0.8);
                        osc.frequency.setValueAtTime(freq, now);

                        gain.gain.setValueAtTime(0, now);
                        gain.gain.linearRampToValueAtTime(this.volume * 0.22, now + 0.015);
                        gain.gain.exponentialRampToValueAtTime(0.01, now + stepDuration * 0.85);

                        osc.start(now);
                        osc.stop(now + stepDuration * 0.9);
                    }

                    // Tambor suave (ruido filtrado) marcando el pulso cada 2 pasos
                    if (this.step % 2 === 0) {
                        const bufferSize = this.ctx.sampleRate * 0.12;
                        const buffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
                        const data = buffer.getChannelData(0);
                        for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;

                        let noise = this.ctx.createBufferSource();
                        noise.buffer = buffer;
                        let noiseFilter = this.ctx.createBiquadFilter();
                        noiseFilter.type = 'lowpass';
                        noiseFilter.frequency.setValueAtTime(this.step % 8 === 0 ? 220 : 320, now);
                        let noiseGain = this.ctx.createGain();
                        noiseGain.gain.setValueAtTime(this.volume * (this.step % 8 === 0 ? 0.32 : 0.18), now);
                        noiseGain.gain.exponentialRampToValueAtTime(0.01, now + 0.12);

                        noise.connect(noiseFilter);
                        noiseFilter.connect(noiseGain);
                        noiseGain.connect(this.ctx.destination);
                        noise.start(now);
                        noise.stop(now + 0.12);
                    }

                    this.step++;
                    this.melodyTimer = setTimeout(playStep, stepDuration * 1000);
                };

                playStep();
            }

            stopMusic() {
                this.musicPlaying = false;
                clearTimeout(this.melodyTimer);
                if (this.droneGain) {
                    const now = this.ctx.currentTime;
                    this.droneGain.gain.cancelScheduledValues(now);
                    this.droneGain.gain.linearRampToValueAtTime(0, now + 0.4);
                    const o1 = this.droneOsc1, o2 = this.droneOsc2;
                    setTimeout(() => { try { o1.stop(); o2.stop(); } catch(e) {} }, 450);
                    this.droneOsc1 = null;
                    this.droneOsc2 = null;
                    this.droneGain = null;
                }
            }
        }

