<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BATTLE CASTLE - Irregular Verbs 3D Game</title>
    <!-- Tailwind CSS para diseño rápido y responsivo -->
    <!-- Silencia el aviso informativo de Tailwind CDN (no es un error, es solo una nota de Tailwind) -->
    <script>
        (function() {
            const originalWarn = console.warn;
            console.warn = function(...args) {
                if (args.some(a => typeof a === 'string' && a.includes('cdn.tailwindcss.com'))) return;
                originalWarn.apply(console, args);
            };
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts Medievales -->
    <link href="https://fonts.googleapis.com/css2?family=Almendra:ital,wght@0,400;0,700;1,400&family=Cinzel+Decorative:wght@700&family=Cinzel:wght@400;700;900&family=MedievalSharp&display=swap" rel="stylesheet">
    
    <style>
        .font-medieval {
            font-family: 'MedievalSharp', cursive, serif;
        }
        .font-cinzel {
            font-family: 'Cinzel', serif;
        }
        .font-decorative {
            font-family: 'Cinzel Decorative', serif;
        }
        
        body {
            font-family: 'Almendra', serif;
            background-color: #0c0813;
            overflow-x: hidden;
            user-select: none;
        }

        /* FONDO PANORÁMICO 3D CON MONTAÑAS Y NEBLINA */
        .mountain-bg {
            background: linear-gradient(to bottom, #110925 0%, #1c0a35 40%, #2e114d 70%, #120524 100%);
        }

        /* ANIMACIONES EN PERSPECTIVA 3D PARA LAS CARTAS */
        .premium-card-container {
            perspective: 1200px;
        }
        .premium-card {
            transform-style: preserve-3d;
            transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.4s ease, border-color 0.4s ease;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.7), inset 0 1px 1px rgba(255, 255, 255, 0.15);
        }
        .premium-card:hover:not(.grayscale) {
            transform: translateY(-8px) rotateX(4deg) rotateY(-4deg);
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.9), 0 0 20px rgba(245, 158, 11, 0.25);
        }

        /* Animación del Rey en 3D (Flotando con volumen) */
        @keyframes breathing {
            0%, 100% { transform: translateY(0px) scale(1) rotate(0deg); filter: drop-shadow(0 4px 6px rgba(0,0,0,0.6)); }
            50% { transform: translateY(-4px) scale(1.02) rotate(1deg); filter: drop-shadow(0 10px 12px rgba(0,0,0,0.4)); }
        }
        .king-idle {
            animation: breathing 3s ease-in-out infinite;
        }

        @keyframes celebration {
            0%, 100% { transform: translateY(0px) rotate(0deg) scale(1); }
            25% { transform: translateY(-12px) rotate(-8deg) scale(1.05); }
            50% { transform: translateY(0px) rotate(8deg) scale(1); }
            75% { transform: translateY(-12px) rotate(-8deg) scale(1.05); }
        }
        .king-correct {
            animation: celebration 0.7s ease-in-out infinite;
        }

        @keyframes defeated {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(6px) rotate(12deg) scale(0.95); }
        }
        .king-incorrect {
            animation: defeated 1.3s ease-in-out infinite;
        }

        @keyframes panicked {
            0%, 100% { transform: translate(0px, 0px) rotate(0deg); }
            20% { transform: translate(-5px, -3px) rotate(-2deg); }
            40% { transform: translate(5px, -5px) rotate(3deg); }
            60% { transform: translate(-4px, 2px) rotate(-1deg); }
            80% { transform: translate(4px, -1px) rotate(2deg); }
        }
        .king-hit {
            animation: panicked 0.15s linear infinite;
        }

        @keyframes run-away {
            0% { transform: translateX(0) scaleX(1); opacity: 1; }
            50% { transform: translateX(40px) scaleX(1); opacity: 0.8; }
            51% { transform: translateX(40px) scaleX(-1); opacity: 0.8; }
            100% { transform: translateX(-150px) scaleX(-1); opacity: 0; }
        }
        .king-destroyed {
            animation: run-away 2.2s ease-in-out forwards;
        }

        /* Ondulación realista de banderas */
        @keyframes flag-wave {
            0%, 100% { transform: skewY(0deg) scaleX(1) rotate(0deg); }
            50% { transform: skewY(6deg) scaleX(0.93) rotate(-2deg); }
        }
        .flag-wave-element {
            animation: flag-wave 1.4s ease-in-out infinite;
            transform-origin: left center;
        }

        /* Pergamino clásico */
        .parchment {
            background: radial-gradient(circle, #fbf3d8 60%, #dfbf7c 100%);
            border: 8px double #5a3a16;
            box-shadow: 0 15px 35px rgba(0,0,0,0.85), inset 0 0 50px rgba(90, 58, 22, 0.45);
        }

        /* Botón de Estilo RPG con relieve e iluminación */
        .rpg-btn {
            background: linear-gradient(180deg, #c3942d, #835c0d);
            border: 2.5px solid #ffe855;
            box-shadow: 0 5px 8px rgba(0,0,0,0.65), inset 0 2px 3px rgba(255,255,255,0.3);
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.9);
            transition: all 0.15s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .rpg-btn:hover:not(:disabled) {
            transform: scale(1.05) translateY(-2px);
            background: linear-gradient(180deg, #ffe855, #a37515);
            box-shadow: 0 8px 15px rgba(255, 232, 85, 0.45);
        }
        .rpg-btn:active:not(:disabled) {
            transform: scale(0.97) translateY(1px);
        }

        /* Sacudida de Pantalla */
        @keyframes shake {
            0%, 100% { transform: translate(0, 0); }
            10% { transform: translate(-7px, -5px) rotate(-1deg); }
            30% { transform: translate(6px, 4px) rotate(1deg); }
            50% { transform: translate(-5px, 7px) rotate(-1deg); }
            70% { transform: translate(7px, -3px) rotate(1deg); }
            90% { transform: translate(-3px, 3px) rotate(0deg); }
        }
        .screen-shake {
            animation: shake 0.4s ease-in-out;
        }

        /* Relieve 3D de cofres */
        .chest-card {
            perspective: 800px;
        }
        .chest-inner {
            transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform-style: preserve-3d;
        }
        .chest-card.flipped .chest-inner {
            transform: rotateY(180deg);
        }
        .chest-front, .chest-back {
            backface-visibility: hidden;
        }
        .chest-back {
            transform: rotateY(180deg);
        }
    </style>
</head>
<body class="min-h-screen text-amber-50 selection:bg-amber-800 selection:text-white flex flex-col justify-between relative mountain-bg">

    <!-- CAPAS DEL PAISAJE MEDIEVAL EN 3D DE FONDO -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
        
        <!-- Cielo estrellado y Neblina lejana -->
        <div class="absolute inset-x-0 top-0 h-2/3 opacity-30 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:24px_24px]"></div>
        
        <!-- Sol/Luna de Fantasía en el Horizonte -->
        <div class="absolute top-20 right-1/4 w-40 h-40 rounded-full bg-gradient-to-tr from-purple-800 to-amber-500 blur-[40px] opacity-25"></div>
        <div class="absolute top-24 right-1/4 w-32 h-32 rounded-full bg-amber-100 opacity-20 filter drop-shadow-[0_0_30px_rgba(251,191,36,0.3)]"></div>

        <!-- Capa de Montañas traseras (Silueta 3D profunda) -->
        <svg class="absolute bottom-[20%] left-0 w-full h-[40vh] opacity-20" viewBox="0 0 1440 320" preserveAspectRatio="none">
            <path d="M0,224 L120,160 L240,240 L360,110 L480,260 L600,180 L720,250 L840,120 L960,240 L1080,150 L1200,210 L1320,90 L1440,240 L1440,320 L0,320 Z" fill="#2d164d"></path>
        </svg>

        <!-- Capa de Montañas medias (Con sombreado de arista para volumen) -->
        <svg class="absolute bottom-[10%] left-0 w-full h-[35vh] opacity-35" viewBox="0 0 1440 320" preserveAspectRatio="none">
            <!-- Lado de sombra de montañas -->
            <path d="M0,240 L200,120 L450,220 L700,90 L1000,230 L1200,130 L1440,220 L1440,320 L0,320 Z" fill="#1b0b2e"></path>
            <!-- Lado de luz de montañas (Crea el efecto 3D) -->
            <path d="M200,120 L450,220 L700,90 L700,320 L200,320 Z" fill="#2d154c" opacity="0.3"></path>
            <path d="M1200,130 L1440,220 L1440,320 L1200,320 Z" fill="#2d154c" opacity="0.3"></path>
        </svg>

        <!-- Capa de Bosque / Pinos Lejanos (Base del mapa) -->
        <svg class="absolute bottom-0 left-0 w-full h-[20vh] opacity-45" viewBox="0 0 1440 150" preserveAspectRatio="none">
            <path d="M0,120 Q120,90 240,110 Q360,130 480,105 Q600,80 720,110 Q840,140 960,115 Q1080,90 1200,110 Q1320,130 1440,120 L1440,150 L0,150 Z" fill="#080312"></path>
            <!-- Pequeños Pinos triangulares en 3D -->
            <polygon points="150,110 160,80 170,110" fill="#080312"></polygon>
            <polygon points="320,120 335,85 350,120" fill="#0c051a"></polygon>
            <polygon points="680,105 690,75 700,105" fill="#080312"></polygon>
            <polygon points="900,125 915,90 930,125" fill="#0c051a"></polygon>
            <polygon points="1150,108 1162,78 1174,108" fill="#080312"></polygon>
        </svg>
    </div>

    <!-- CANVAS PARA DISPAROS, PARTÍCULAS, EXPLOSIONES, CONFETI Y FUEGOS ARTIFICIALES -->
    <canvas id="battle-canvas" class="fixed inset-0 w-full h-full pointer-events-none z-50"></canvas>

    <!-- ENCABEZADO DEL JUEGO CON CONTROLES -->
    <header class="z-10 w-full bg-gradient-to-b from-stone-950 via-stone-950/75 to-transparent p-4 flex flex-wrap justify-between items-center gap-4 border-b border-purple-900/40">
        <div class="flex items-center gap-3">
            <span class="text-4xl filter drop-shadow-[0_2px_8px_rgba(251,191,36,0.5)]">🏰</span>
            <div>
                <h1 class="text-2xl md:text-3xl font-cinzel font-black tracking-widest text-amber-400 drop-shadow-[0_2px_10px_rgba(0,0,0,0.9)]">BATTLE CASTLE</h1>
                <p class="text-[10px] md:text-xs tracking-wider text-purple-300 font-medieval uppercase">Guerra de Verbos Irregulares • Versión 3D Premium</p>
            </div>
        </div>

        <!-- CONTROLES ADICIONALES -->
        <div class="flex items-center gap-3 bg-stone-950/90 p-2 rounded-xl border border-purple-900/30 backdrop-blur-md shadow-2xl">
            <!-- Música -->
            <button id="music-btn" onclick="toggleMusic()" class="p-2 hover:bg-stone-800 rounded-lg text-lg" title="Música Medieval">
                🎵 <span class="text-xs" id="music-status">OFF</span>
            </button>
            <div class="flex items-center gap-1">
                <span class="text-xs text-stone-400">Vol:</span>
                <input id="volume-slider" type="range" min="0" max="1" step="0.1" value="0.5" onchange="updateVolume(this.value)" class="w-16 h-1 bg-purple-950 rounded-lg appearance-none cursor-pointer">
            </div>

            <div class="h-5 w-[1px] bg-purple-900/50"></div>

            <!-- Pantalla Completa -->
            <button onclick="toggleFullscreen()" class="p-2 hover:bg-stone-800 rounded-lg text-sm" title="Pantalla Completa">
                📺
            </button>
            
            <!-- Reiniciar -->
            <button onclick="triggerResetConfirm()" class="p-2 hover:bg-red-950 hover:text-red-300 rounded-lg text-sm text-red-400" title="Reiniciar Partida">
                🔄
            </button>
        </div>
    </header>

    <!-- CONTENEDOR PRINCIPAL DEL JUEGO -->
    <main id="game-container" class="z-10 flex-grow w-full max-w-7xl mx-auto p-4 flex flex-col justify-center">
        
        <!-- ================= PANTALLA 1: CONFIGURACIÓN ================= -->
        <section id="screen-setup" class="page-transition w-full max-w-2xl mx-auto p-6 md:p-8 rounded-2xl shadow-2xl parchment text-stone-900">
            <h2 class="text-3xl md:text-4xl font-decorative text-center text-amber-950 mb-1 font-bold">⚔️ ALZAD VUESTROS CASTILLOS 3D ⚔️</h2>
            <p class="text-center text-sm text-amber-900 mb-6 font-medieval">Estableced los nombres de las 5 fortalezas reales para comenzar la batalla de la gramática inglesa.</p>
            
            <div class="space-y-4 mb-6" id="setup-castles-list">
                <!-- Se autogeneran los inputs de reinos -->
            </div>

            <div class="flex flex-col sm:flex-row gap-4 justify-between items-center bg-amber-950/10 p-4 rounded-xl border border-amber-900/30">
                <div class="flex items-center gap-3">
                    <input type="checkbox" id="timer-toggle" checked class="w-5 h-5 accent-amber-800">
                    <label for="timer-toggle" class="text-sm font-semibold text-amber-950 cursor-pointer font-medieval">
                        Activar temporizador de asedio (15 Segundos) ⏱️
                    </label>
                </div>
            </div>

            <button onclick="startGame()" class="rpg-btn w-full mt-6 py-4 px-8 text-xl md:text-2xl font-medieval text-white font-bold rounded-xl tracking-wider flex justify-center items-center gap-3 shadow-2xl">
                ⚔️ COMENZAR BATALLA ⚔️
            </button>
        </section>

        <!-- ================= PANTALLA 2: JUEGO ACTIVO ================= -->
        <section id="screen-game" class="page-transition hidden grid grid-cols-1 lg:grid-cols-4 gap-6">
            
            <!-- ARENA CENTRAL (3 columnas) -->
            <div class="lg:col-span-3 flex flex-col gap-6">
                
                <!-- Turno Actual y Acciones -->
                <div id="turn-banner" class="bg-gradient-to-r from-stone-950/95 to-slate-900/90 border-2 border-amber-500 rounded-2xl p-5 shadow-2xl relative overflow-hidden backdrop-blur-md">
                    <!-- Detalle dorado superior de la carta de turno -->
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-amber-400 via-yellow-300 to-amber-500"></div>
                    
                    <div class="relative z-10 flex flex-col sm:flex-row justify-between items-center gap-4">
                        <div class="text-left">
                            <span class="text-xs uppercase tracking-widest text-amber-400 font-bold block mb-1">🎮 Comandando Turno</span>
                            <h3 id="active-player-name" class="text-2xl md:text-3xl font-medieval text-white tracking-wide">Castillo de Prueba</h3>
                        </div>

                        <!-- Botones de Acción Directa -->
                        <div class="flex items-center gap-3">
                            <button id="bonus-btn" onclick="openBonusChestSelection()" class="px-4 py-3.5 bg-gradient-to-r from-purple-800 to-indigo-950 hover:from-purple-700 hover:to-indigo-900 border-2 border-purple-400 text-white rounded-xl text-sm md:text-base font-medieval tracking-wider shadow-xl flex items-center gap-2 transition duration-200">
                                🎁 COFRE DE RECURSOS
                            </button>
                            <button onclick="promptQuestionSelection()" class="rpg-btn px-6 py-4 text-base md:text-lg font-medieval text-white font-bold rounded-xl flex items-center gap-2 shadow-lg">
                                📜 RESPONDER PREGUNTA
                            </button>
                        </div>
                    </div>
                </div>

                <!-- CAMPO DE BATALLA: Mapa de Reinos -->
                <div id="battle-arena" class="relative rounded-2xl border-4 border-amber-700/50 overflow-hidden shadow-2xl premium-card-container" style="aspect-ratio: 16/10.5; min-height: 480px; background: radial-gradient(ellipse at 50% 45%, #14606e 0%, #0c4956 45%, #07303c 75%, #041d26 100%);">
                    <!-- Marco interior dorado estilo pergamino de mapa -->
                    <div class="absolute inset-2 rounded-xl border-2 border-amber-500/25 pointer-events-none z-30"></div>

                    <!-- Capa de Terreno Pintado (bosques, montañas, cristales, hielo) -->
                    <svg id="map-terrain" class="absolute inset-0 w-full h-full" viewBox="0 0 1000 625" preserveAspectRatio="xMidYMid slice"></svg>

                    <!-- Capa de Rutas Punteadas entre Reinos -->
                    <svg id="map-routes" class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1000 625" preserveAspectRatio="xMidYMid slice"></svg>

                    <!-- Brújula decorativa -->
                    <div class="absolute top-3 left-3 z-20 opacity-70 pointer-events-none select-none">
                        <svg viewBox="0 0 60 60" class="w-10 h-10 md:w-12 md:h-12 drop-shadow-lg">
                            <circle cx="30" cy="30" r="27" fill="none" stroke="#fbbf24" stroke-width="1.5" opacity="0.7"/>
                            <path d="M30 6 L34 30 L30 54 L26 30 Z" fill="#fbbf24" opacity="0.85"/>
                            <path d="M6 30 L30 26 L54 30 L30 34 Z" fill="#fde68a" opacity="0.65"/>
                            <text x="30" y="14" text-anchor="middle" fill="#fef3c7" font-size="8" font-weight="bold">N</text>
                        </svg>
                    </div>

                    <!-- Marcadores de Castillos inyectados dinámicamente -->
                    <div id="castle-markers-layer" class="absolute inset-0 z-20"></div>
                </div>
            </div>

            <!-- PANEL LATERAL DE INFORMACIÓN (1 columna) -->
            <div class="bg-stone-950/95 border-2 border-purple-900/30 rounded-2xl p-4 shadow-2xl flex flex-col justify-between gap-6 backdrop-blur-md">
                
                <!-- Tabla de Clasificación / Estatus -->
                <div>
                    <h3 class="text-lg font-medieval text-amber-400 border-b border-purple-900/30 pb-2 mb-3 flex items-center justify-between">
                        <span>📊 REINOS</span>
                        <span class="text-xs text-stone-500">HP / RECURSOS</span>
                    </h3>
                    <div id="sidebar-leaderboard" class="space-y-3">
                        <!-- Ránking dinámico -->
                    </div>
                </div>

                <!-- Historial de Combate -->
                <div class="flex-grow flex flex-col min-h-[140px]">
                    <h3 class="text-base font-medieval text-stone-300 border-b border-purple-900/30 pb-2 mb-2">
                        <span>📜 CRÓNICA DE GUERRA</span>
                    </h3>
                    <div id="battle-log" class="flex-grow overflow-y-auto max-h-[160px] text-[11px] space-y-2 text-stone-400 pr-1">
                        <!-- Entradas dinámicas del log -->
                    </div>
                </div>

                <!-- Cuadrícula de Preguntas Usadas -->
                <div>
                    <h4 class="text-xs font-medieval text-amber-500/80 uppercase tracking-widest mb-2">Pergaminos Utilizados</h4>
                    <div id="questions-used-grid" class="grid grid-cols-6 gap-1 text-[10px] text-center">
                        <!-- 1 al 30 de forma reducida -->
                    </div>
                </div>
            </div>
        </section>

        <!-- ================= PANTALLA 3: VICTORIA ================= -->
        <section id="screen-victory" class="page-transition hidden w-full max-w-xl mx-auto bg-stone-950/95 p-8 rounded-3xl border-4 border-yellow-500 text-center shadow-2xl relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-yellow-500/10 via-transparent to-transparent pointer-events-none"></div>
            
            <div class="text-6xl mb-4 animate-bounce">👑</div>
            <h2 class="text-4xl font-decorative text-yellow-400 mb-1 font-black tracking-widest">VICTORIA ABSOLUTA</h2>
            <p class="text-stone-400 font-medieval uppercase tracking-wider mb-6">El soberano supremo es:</p>
            
            <div class="bg-gradient-to-r from-amber-950/60 via-amber-900/40 to-amber-950/60 p-5 rounded-2xl border border-yellow-500/30 mb-6">
                <h3 id="victory-castle-name" class="text-3xl font-medieval text-yellow-300 tracking-wide font-bold">Castillo Ganador</h3>
                <p class="text-xs text-amber-400 mt-2 font-medieval">¡Todos los reinos se rinden ante su gloriosa sabiduría!</p>
            </div>

            <!-- Animación del Rey Victorioso en SVG -->
            <div class="w-36 h-36 mx-auto mb-6 flex justify-center" id="victory-king-container"></div>

            <button onclick="triggerResetGame()" class="rpg-btn w-full py-4 px-8 text-xl font-medieval text-white font-bold rounded-xl tracking-wider flex justify-center items-center gap-2 shadow-lg">
                🏆 NUEVA CAMPAÑA 🏆
            </button>
        </section>

    </main>

    <!-- FOOTER -->
    <footer class="z-10 w-full text-center p-3 bg-stone-950/60 text-stone-500 text-[10px] font-medieval border-t border-purple-950/40 backdrop-blur-md">
        <p>Battle Castle • Desarrollado con HTML5, Canvas y Web Audio API • 100% Sin Servidor</p>
    </footer>

    <!-- ================= MODAL: SELECCIÓN DE NÚMERO DE PREGUNTA ================= -->
    <div id="modal-pergaminos" class="fixed inset-0 bg-black/80 z-50 backdrop-blur-sm hidden flex items-center justify-center p-4">
        <div class="bg-stone-950/95 border-4 border-amber-800 rounded-3xl p-5 max-w-2xl w-full parchment text-stone-900 relative shadow-2xl">
            <button onclick="closeModal('modal-pergaminos')" class="absolute top-4 right-4 text-stone-700 hover:text-stone-900 text-2xl font-bold">✕</button>
            
            <h3 class="text-2xl font-medieval text-center text-amber-950 mb-1 font-bold">📜 SELECCIONAD UN PERGAMINO</h3>
            <p class="text-center text-xs text-amber-900 mb-5 font-medieval">Cada pergamino esconde un verbo en Pasado Simple único. Elegid uno.</p>

            <div class="grid grid-cols-5 sm:grid-cols-6 gap-2" id="pergaminos-grid-selection">
                <!-- Generado por JavaScript -->
            </div>
        </div>
    </div>

    <!-- ================= MODAL: HOJA DE PREGUNTA ACTIVADA ================= -->
    <div id="modal-pregunta" class="fixed inset-0 bg-black/90 z-50 backdrop-blur-md hidden flex items-center justify-center p-4">
        <div class="bg-gradient-to-b from-stone-900 to-slate-950 border-4 border-amber-600 rounded-3xl p-6 max-w-xl w-full relative overflow-hidden shadow-2xl">
            <!-- Barra del temporizador -->
            <div id="timer-bar-container" class="absolute top-0 left-0 right-0 h-2 bg-stone-800">
                <div id="timer-bar" class="h-full bg-gradient-to-r from-amber-500 to-red-650 transition-all duration-1000" style="width: 100%;"></div>
            </div>

            <!-- Marcador superior de tiempo -->
            <div class="flex justify-between items-center mb-6 mt-2">
                <span class="text-xs uppercase tracking-widest text-amber-400 font-bold font-medieval" id="question-index-label">Pergamino #XX</span>
                <span class="text-base font-medieval text-red-400 font-bold" id="countdown-label">⏱️ 15s</span>
            </div>

            <div class="text-center mb-8">
                <span class="text-stone-400 text-sm block mb-1 font-medieval">¿Cuál es el infinitivo (presente) de este verbo en Pasado Simple?</span>
                <h4 id="question-verb" class="text-4xl md:text-5xl font-cinzel font-black tracking-widest text-white drop-shadow-[0_2px_10px_rgba(255,255,255,0.15)]">WENT</h4>
            </div>

            <!-- Opciones -->
            <div class="space-y-4" id="alternatives-container">
                <!-- Se inyectan las alternativas de respuesta -->
            </div>
        </div>
    </div>

    <!-- ================= MODAL: BONO - COFRES DE LA FORTUNA ================= -->
    <div id="modal-bonus" class="fixed inset-0 bg-black/90 z-50 backdrop-blur-md hidden flex items-center justify-center p-4">
